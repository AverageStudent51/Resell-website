# Required: PostgreSQL database connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Required for secure login sessions
SESSION_SECRET=replace-this-with-a-long-random-secret

# Optional: choose the one account allowed to become admin.
# If blank, the first registered user becomes the only admin automatically.
ADMIN_EMAIL=

# Optional but recommended in production
# Set this to your real domain for Stripe redirects and email verification links.
CLIENT_BASE_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# Optional: real email verification through Resend.
# Leave EMAIL_VERIFICATION_REQUIRED=false for easy local testing.
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_FROM=
RESEND_API_KEY=

# Legacy optional team lookup fields. Not needed for AreaOffers.
TEAM_VERIFY_REQUIRED=false
FIRST_API_SEASON=2026
FIRST_API_USERNAME=
FIRST_API_AUTH_TOKEN=
TBA_AUTH_KEY=

# Optional: Cloudinary image uploads. Without these, local uploads work only for testing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: Stripe checkout. Without this, purchases use demo mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
